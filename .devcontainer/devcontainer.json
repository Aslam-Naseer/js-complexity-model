{
  "name": "Complexity Model",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
        "python.terminal.activateEnvironment": true
      },
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "mounts": [
    "source=shared-uv-cache,target=/home/vscode/.cache/uv,type=volume",
    "source=shared-hf-cache,target=/home/vscode/.cache/huggingface,type=volume",
    "source=js-model-node-modules,target=${containerWorkspaceFolder}/code_analyzer/node_modules,type=volume",
    "source=js-model-venv,target=${containerWorkspaceFolder}/.venv,type=volume"
  ],
  "containerEnv": {
    "UV_CACHE_DIR": "/home/vscode/.cache/uv",
    "UV_LINK_MODE": "hardlink"
  },
  "postCreateCommand": "sudo chown -R $(whoami) /home/vscode/.cache && sudo chown -R vscode:vscode ${containerWorkspaceFolder}/.venv && sudo chown -R vscode:vscode ${containerWorkspaceFolder}/code_analyzer/node_modules && uv sync",
  "remoteUser": "vscode"
}